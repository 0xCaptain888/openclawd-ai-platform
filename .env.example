# ==============================================================================
# AI 统一平台 - 环境变量配置
# ==============================================================================

# ---------- LLM 后端配置 ----------
# vLLM 服务地址（宿主机运行时使用 host.docker.internal）
LLM_API_URL=http://host.docker.internal:8000/v1
MODEL_NAME=Qwen2-72B-Instruct-GPTQ-Int4

# ---------- API Gateway 配置 ----------
GATEWAY_PORT=80

# API 密钥（逗号分隔: key:name:rpm:daily_quota）
# rpm = 每分钟请求数, daily_quota = 每日最大请求数
API_KEYS=sk-admin-001:admin:120:50000,sk-social-001:social-bot:60:20000,sk-web-001:website:60:20000,sk-trade-001:trading:30:10000

# ---------- 各服务 API 密钥（服务间认证） ----------
SOCIAL_BOT_API_KEY=sk-social-internal-001
WEBSITE_BACKEND_API_KEY=sk-web-internal-001
TRADING_API_KEY=sk-trade-internal-001

# ---------- Redis 配置 ----------
REDIS_URL=redis://redis:6379/0

# ---------- 社交机器人服务 ----------
SOCIAL_BOT_PORT=8010

# ---------- 网站服务 ----------
WEBSITE_FRONTEND_PORT=3000
WEBSITE_BACKEND_PORT=4000

# ---------- 交易服务 ----------
TRADING_PORT=8020

# ---------- 日志级别 ----------
LOG_LEVEL=INFO
